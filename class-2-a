function alpha=backtrack(fun,gfun,p,x,alpha,c ,rho)
    while fun(x+alpha*p)>fun(x)+alpha*c*dot(gfun(x),p)
        alpha=rho*alpha;
    end
end



%%
function x0=gradmeth(fun,gfun,x0,tol)
while norm(gfun(x0))>tol
    p=-gfun(x0);
    alpha=backtrack(fun,gfun,p,x0,0.4,1e-4,0.5)
    x0=x0+alpha*p;
end
end

